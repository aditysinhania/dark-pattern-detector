# ── Application ────────────────────────────────────────────────
APP_NAME="Dark Pattern Detector"
APP_ENV=development          # development | staging | production
DEBUG=true
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Database ───────────────────────────────────────────────────
POSTGRES_USER=darkpattern
POSTGRES_PASSWORD=darkpattern_dev_password
POSTGRES_DB=darkpattern_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://darkpattern:darkpattern_dev_password@db:5432/darkpattern_db

# ── Redis ──────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ── Celery ─────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── JWT ────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── File Storage ───────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ── AI Model ───────────────────────────────────────────────────
MODEL_PATH=./ai/models
MODEL_VERSION=v1

# ── Optional: OpenAI for LLM reasoning step ────────────────────
OPENAI_API_KEY=sk-your-key-here